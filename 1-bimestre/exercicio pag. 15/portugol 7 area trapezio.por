programa
{
	
	funcao inicio()
	{
	    inteiro baseME, baseMA, altura,area
	    escreva("cauculo da area de um trapezio \n\n")
	    escreva("qual a base menor do trapezio? \n\n ")
	    escreva("qual a base maior do trapezio? \n\n ")
	     escreva("qual a altura do trapezio? \n\n")
	    leia (baseME,baseMA,altura)
	    area = (baseME + baseMA) + altura/2
         escreva("a area do seu trapezio é de ",area,"")
      

	}
}
