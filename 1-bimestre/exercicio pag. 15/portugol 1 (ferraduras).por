programa
{
    funcao inicio()
    {
        inteiro cavalos, ferraduras

        escreva("Digite a quantidade de cavalos: ")
        leia(cavalos)

        ferraduras = cavalos * 4

        escreva("Quantidade de cavalos: ", cavalos)
        escreva(" Quantidade de ferraduras necessárias: ", ferraduras)
    }
}
