programa
{
	
	funcao inicio()
	{
	    inteiro nota1,nota2,nota3,nota4, resultado 
	    escreva("calculo da media dos alunos \n\n\n")
	    escreva("qual sua 1 primeira nota? \n")
	    escreva("qual sua 2 primeira nota? \n")
	    escreva("qual sua 3 primeira nota? \n")
	    escreva("qual sua 4 primeira nota? \n")

	    leia(nota1,nota2,nota3,nota4)
	    resultado = (nota1*1 + nota2*2 + nota3*3 + nota4*4)/10
       
        escreva("a sua media é",resultado,"\n\n\n")
        
	}
}
	
	
