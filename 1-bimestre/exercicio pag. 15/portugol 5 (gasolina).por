programa
{
	
	funcao inicio()
	{
	    inteiro Pgasolina, litros, reais
	    escreva("valor abastecido \n\n\n")
	    escreva("quantos reais você tem para abastecer o carro? \n") 
	    escreva("qual o valor do combustivel? \n")
	   
	    leia(reais, Pgasolina)
	    litros = reais/Pgasolina
      
        escreva("você pode abastecer ",litros," litros com ",reais," reais \n\n\n")
        
	}
}
	
	
