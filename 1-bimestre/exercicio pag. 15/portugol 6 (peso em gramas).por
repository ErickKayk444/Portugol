programa
{
	
	funcao inicio()
	{
	    inteiro pesoK,pesoG
	    escreva("cauculo do seu peso em gramas \n\n")
	    escreva("quantos quilos voce tem? ")
	    leia (pesoK)
	    pesoG = pesoK*1000
         escreva("seu peso em gramas é de ",pesoG,"")
      

	}
}
