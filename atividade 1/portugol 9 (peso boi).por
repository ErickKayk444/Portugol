programa
{
	
	funcao inicio()
	{
	    inteiro pesoB, percentualCRE,engordou,pesoFIN
	    escreva("calclo do peso do boi \n\n")
	    escreva("qual peso do boi? \n\n ")
	    escreva("quantos porcento ele engordou? \n\n ")
	    leia (pesoB, percentualCRE)
	    engordou = pesoB* percentualCRE/100
	    pesoFIN = engordou +pesoB
         escreva("o peso do boi é de ",pesoFIN,"")
      

	}
}
