programa
{
	
	funcao inicio()
	{
	    inteiro salarioFIXO, valorDA, percentualDA, salarioFINAL
	    escreva("calclo do salario \n\n")
	    escreva("qual o seu fixo? \n\n ")
	    escreva("quantos reais voce vendeu? \n\n ")
	     escreva("qual o percentual das vendas? \n\n")
	    leia (salarioFIXO, valorDA, percentualDA)
	    salarioFINAL = salarioFIXO + (valorDA * percentualDA/100)
         escreva("o salario final é de ",salarioFINAL,"")
      

	}
}
